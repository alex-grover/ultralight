{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "sortImports": {
    "enabled": true
  },
  "sortTailwindcss": {
    "enabled": true
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [".next/**", "node_modules/**"]
}
