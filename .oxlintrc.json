{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "plugins": ["typescript", "react", "nextjs", "jsx-a11y"],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "warn"
  },
  "ignorePatterns": [".next/**", "node_modules/**"]
}
